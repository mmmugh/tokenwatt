#!/bin/sh
# tokenwatt: refuse to push commits/tags whose ADDED content matches a leak
# pattern. This is the net for `git push` and `git tag` pushes — moments a
# pre-commit hook never sees. git feeds ref updates on stdin, one per line:
#   <local ref> <local sha> <remote ref> <remote sha>
set -eu

HOOK_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
EMPTY_TREE=4b825dc642cb6eb9a060e54bf8d69288fbee4904
Z40=0000000000000000000000000000000000000000

fail=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a remote ref (local sha all zeros) — nothing to scan.
  [ "$local_sha" = "$Z40" ] && continue
  # New ref on the remote (remote sha all zeros) — scan everything as added,
  # by diffing against the empty tree. Otherwise scan only what's new.
  if [ "$remote_sha" = "$Z40" ]; then base="$EMPTY_TREE"; else base="$remote_sha"; fi
  # Fail closed: if the base object isn't here (force-push, divergent remote,
  # shallow clone), scan everything as added rather than scanning nothing.
  if [ "$base" != "$EMPTY_TREE" ] && ! git cat-file -e "${base}^{commit}" 2>/dev/null; then
    base="$EMPTY_TREE"
  fi
  if ! git diff --no-color -U0 "$base" "$local_sha" | "$HOOK_DIR/leak-scan"; then
    echo "pre-push: leak-scan blocked $local_ref (see above)." >&2
    fail=1
  fi
done

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "pre-push: refusing to push. Fix the content, or override: git push --no-verify" >&2
  exit 1
fi
exit 0
