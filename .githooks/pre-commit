#!/bin/sh
# TokenWatt: auto-increment the patch (3rd) tier of VERSION on every commit.
# Starts at 0.1.0 (seeded). Bypass for a commit with: git commit --no-verify
set -e

VERSION_FILE="VERSION"
[ -f "$VERSION_FILE" ] || printf '0.1.0\n' > "$VERSION_FILE"

cur=$(tr -d '[:space:]' < "$VERSION_FILE")
major=${cur%%.*}
rest=${cur#*.}
minor=${rest%%.*}
patch=${rest#*.}

# Guard against a malformed VERSION
case "$major.$minor.$patch" in
  *[!0-9.]*|.*|*..*|*.) echo "pre-commit: malformed VERSION '$cur'"; exit 1 ;;
esac

patch=$((patch + 1))
new="$major.$minor.$patch"
printf '%s\n' "$new" > "$VERSION_FILE"
git add "$VERSION_FILE"
echo "tokenwatt: VERSION $cur -> $new"
